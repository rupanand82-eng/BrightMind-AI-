{
  "entities": {
    "User": {
      "title": "User",
      "description": "The pilot user credentials and scholastic progress state",
      "type": "object",
      "properties": {
        "userId": {
          "type": "string"
        },
        "name": {
          "type": "string"
        },
        "role": {
          "type": "string"
        },
        "energyPoints": {
          "type": "integer"
        },
        "streak": {
          "type": "integer"
        },
        "updatedAt": {
          "type": "string",
          "format": "date-time"
        }
      },
      "required": ["userId", "name", "role", "energyPoints", "streak", "updatedAt"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "User account and gamification statistics"
    }
  }
}
