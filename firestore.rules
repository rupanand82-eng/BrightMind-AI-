rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Global safety net: deny all by default
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // Validation for User entity
    function isValidUser(data) {
      return data.size() == 6
        && data.userId is string && data.userId.size() <= 128
        && data.name is string && data.name.size() > 0 && data.name.size() <= 100
        && data.role is string && (data.role == 'biology' || data.role == 'physics' || data.role == 'computer_science')
        && data.energyPoints is int && data.energyPoints >= 0 && data.energyPoints <= 1000000
        && data.streak is int && data.streak >= 0 && data.streak <= 3650
        && (data.updatedAt is timestamp || data.updatedAt is string);
    }

    // Users collection mapping
    match /users/{userId} {
      allow get: if isOwner(userId);
      allow create: if isOwner(userId) 
        && isValidId(userId) 
        && isValidUser(incoming())
        && incoming().userId == userId;
      
      allow update: if isOwner(userId)
        && isValidUser(incoming())
        && incoming().userId == existing().userId;

      allow delete: if isOwner(userId);
    }
  }
}
